.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.cta-reassure {
  margin-top: 1.8rem;
  font-size: 0.7rem;
  color: rgba(255,255,255,0.28);
  font-style: italic;
  font-family: 'Libre Baskerville', serif;
}

/* ── FOOTER ── */
footer {
