.figli-body strong { color: white; font-weight: 500; }
.figli-note {
  font-family: 'Libre Baskerville', serif;
  font-style: italic;
  font-size: 0.95rem;
  color: rgba(255,255,255,0.6);
  line-height: 1.7;
  border-left: 2px solid rgba(255,255,255,0.3);
  padding-left: 1rem;
}

/* ── CTA ── */
.section-cta {
  background: var(--ink);
  padding: 4rem 1.6rem;
