<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soavitas | Fragilità Cognitiva</title>
<link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;1,6..96,300;1,6..96,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0f0e0d;
  --cream: #F2EDE5;
  --gold: #B8924A;
  --sage: #4A6350;
  --warm: #FAF7F2;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', sans-serif;
  background: var(--cream);
  color: var(--ink);
  overflow-x: hidden;
}

/* ── HERO ── */
.hero {
  background: var(--ink);
  padding: 4rem 1.6rem 3.5rem;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 220px; height: 220px;
  border-radius: 50%;
  border: 1px solid rgba(184,146,74,0.12);
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -40px; left: -40px;
  width: 160px; height: 160px;
  border-radius: 50%;
  border: 1px solid rgba(184,146,74,0.08);
}
.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rem;
}
.nav-logo {
  font-family: 'Bodoni Moda', serif;
  font-size: 1.4rem;
  font-style: italic;
  color: white;
  text-decoration: none;
  letter-spacing: 0.04em;
}
.nav-back {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.nav-back:hover { color: var(--gold); }

.hero-eyebrow {
  font-size: 0.55rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.2rem;
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 2rem; height: 1px;
  background: var(--gold);
  flex-shrink: 0;
}

.hero-title {
  font-family: 'Bodoni Moda', serif;
  font-size: clamp(2.6rem, 10vw, 4rem);
  font-weight: 400;
  line-height: 1.1;
  color: white;
  margin-bottom: 1.8rem;
}
.hero-title em {
  font-style: italic;
  color: var(--gold);
}

.hero-intro {
  font-family: 'Libre Baskerville', serif;
  font-size: 1rem;
  font-style: italic;
  line-height: 1.8;
  color: rgba(255,255,255,0.78);
  border-left: 2px solid var(--gold);
  padding-left: 1.2rem;
  margin-bottom: 2.5rem;
}

.hero-note {
  font-size: 0.72rem;
  font-weight: 300;
  color: rgba(255,255,255,0.45);
  line-height: 1.8;
  letter-spacing: 0.02em;
}

/* ── SEZIONE DOLORE ── */
.section-dolore {
  background: var(--warm);
  padding: 4rem 1.6rem;
}
.s-label {
  font-size: 0.55rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.4rem;
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
.s-label::before {
  content: '';
  display: block;
  width: 2rem; height: 1px;
  background: var(--gold);
  flex-shrink: 0;
}
.s-title {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(1.6rem, 6vw, 2.2rem);
  font-weight: 400;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 2rem;
}
.s-title em { font-style: italic; color: var(--sage); }

.pain-items {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.pain-item {
  padding: 1.1rem 0;
  border-bottom: 1px solid rgba(17,17,16,0.08);
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.pain-item:first-child { border-top: 1px solid rgba(17,17,16,0.08); }
.pain-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
  margin-top: 0.45rem;
}
.pain-text {
  font-size: 0.88rem;
  line-height: 1.75;
  color: rgba(17,17,16,0.72);
}
.pain-text strong { color: var(--ink); font-weight: 500; }

/* ── SEZIONE METODO ── */
.section-metodo {
  background: var(--ink);
  padding: 4rem 1.6rem;
