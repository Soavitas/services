  color: var(--gold);
  margin-bottom: 2rem;
}
.metodo-body {
  font-size: 0.9rem;
  font-weight: 300;
  line-height: 2;
  color: rgba(255,255,255,0.82);
  margin-bottom: 2.5rem;
}
.metodo-body strong { color: white; font-weight: 500; }

.pillars {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.pillar {
  padding: 1.2rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  display: flex;
  gap: 1.2rem;
  align-items: flex-start;
}
.pillar:first-child { border-top: 1px solid rgba(255,255,255,0.07); }
.pillar-num {
  font-family: 'Bodoni Moda', serif;
  font-style: italic;
  font-size: 1.4rem;
  color: var(--gold);
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.1rem;
}
.pillar-title {
  font-size: 0.88rem;
  font-weight: 500;
  color: white;
  margin-bottom: 0.25rem;
}
.pillar-desc {
  font-size: 0.78rem;
  font-weight: 300;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
}

/* ── TESTIMONIANZA ── */
.section-testimonianza {
  background: var(--cream);
  padding: 4rem 1.6rem;
}
.testi-pull {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(1.05rem, 4vw, 1.3rem);
  font-style: italic;
  line-height: 1.75;
  color: var(--ink);
  margin-bottom: 1rem;
}
.testi-cite {
  font-size: 0.58rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
}

/* ── PER I FIGLI ── */
.section-figli {
